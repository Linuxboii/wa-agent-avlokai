# ---- Copy to .env and fill in. Never commit the real .env ----

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Cloud API (Meta) — from developers.facebook.com app
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx          # permanent system-user access token
WHATSAPP_BUSINESS_ID=000000000000000        # WhatsApp Business Account ID
WHATSAPP_PHONE_NUMBER_ID=000000000000000    # Phone Number ID
WHATSAPP_VERIFY_TOKEN=choose-any-random-string   # used in Meta webhook setup
WHATSAPP_APP_SECRET=your_app_secret         # App > Settings > Basic (for sig verify)
WHATSAPP_API_VERSION=v21.0

# Auth (dashboard) — single shared agent
AGENT_USERNAME=admin
AGENT_PASSWORD=change-me-now                # used by create_agent.py to seed login
JWT_SECRET=generate-a-long-random-string
JWT_EXPIRE_HOURS=24

# Database
DATABASE_URL=postgresql+asyncpg://avlok:avlok_pw@localhost:5432/avlok_wa

# Public HTTPS base URL of this server (used in logs / media links)
PUBLIC_BASE_URL=https://wa.yourdomain.com

# Where downloaded media is stored on disk
MEDIA_DIR=/var/lib/avlok-wa/media

# CORS: extra explicit origin(s), comma-separated. Wildcard '*' is rejected.
# These provider families are ALREADY allowed by built-in regex (CORS_ORIGIN_REGEX):
#   *.avlokai.com, *.devtunnels.ms, *.github.io, *.ngrok.app/.ngrok-free.app/.ngrok.io,
#   *.vercel.app, localhost. Only add origins here that fall outside those.
CORS_ORIGINS=
# Override the allowed-origin regex if needed (advanced):
# CORS_ORIGIN_REGEX=^https?://(...)$
